{
  "name": "thekiharani/laravel-payments",
  "description": "Laravel SDK for payment integrations: M-PESA Daraja, SasaPay, KCB Buni, and Paystack.",
  "keywords": [
    "laravel",
    "payments",
    "mpesa",
    "daraja",
    "kcb-buni",
    "sasapay",
    "paystack",
    "kenya"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Joseph Gitonga",
      "email": "thekiharani@gmail.com",
      "homepage": "https://github.com/thekiharani"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/http": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "NoriaLabs\\Payments\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NoriaLabs\\Payments\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "NoriaLabs\\Payments\\Providers\\PaymentsServiceProvider"
      ],
      "aliases": {
        "Payments": "NoriaLabs\\Payments\\Facades\\Payments"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
